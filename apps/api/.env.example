# API
DATABASE_URL=postgresql://pazaryeri:pazaryeri@localhost:5432/pazaryeri?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# OpenSearch
OPENSEARCH_URL=http://localhost:9200

# Auth
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars!!
JWT_REFRESH_SECRET=change-me-too-in-production-min-32!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# App
NODE_ENV=development
PORT=4000
API_VERSION=1

# S3-compatible storage (local dev: MinIO or R2)
S3_ENDPOINT=
S3_BUCKET_QUARANTINE=pazaryeri-quarantine
S3_BUCKET_PUBLIC=pazaryeri-public
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Feature flags (overridden by DB FeatureFlag table in production)
PAYMENTS_ENABLED=false

# CSRF
CSRF_SECRET=change-me-csrf-secret-min-32-chars!!!

# OpenTelemetry (optional — set OTEL_ENABLED=true in production)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=turkiye-pazaryeri-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
